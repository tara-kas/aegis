.DS_Store

# Environment variables (contains sensitive API keys)
.env
.env.local
.env.production.local
.env.development.local
.env.test
**/.env

# Dependencies
node_modules/

# Build output
dist/
build/

# Lockfiles — keep package-lock.json for reproducible installs
bun.lockb
yarn.lock
pnpm-lock.yaml

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Vitest results cache
node_modules/.vite/

# Test coverage and results
coverage/
*.lcov
test-results/

# Logs
logs/
*.log
*.jsonl
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Temporary files
*.tmp
*.temp
.cache/

# Editor / IDE directories
.vscode/
.idea/
.cursor/
.claude/
*.swp
*.swo
*~

# Solana wallet keypair — NEVER commit private keys
aegis-wallet.json

# Generated files
*.pdf

