# Aegis Unified System - Environment Configuration
# Copy this file to .env and fill in the values below

# ─────────────────────────────────────────────────────────────────────────────
# 1. Supabase (Database & Realtime)
# Replace these with your actual Supabase project URL and anon/service keys.
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Backend aliases for Python core (falls back to VITE_ keys if not set)
BACKEND_URL="http://localhost:54321" # Edge functions / Local API routing

# ─────────────────────────────────────────────────────────────────────────────
# 2. AI & Language Models
# ─────────────────────────────────────────────────────────────────────────────
# Crusoe Cloud (DeepSeek-R1)
# If CRUSOE_API_KEY is omitted, the system falls back to `USE_LOCAL_MODEL` (Mistral via Ollama).
CRUSOE_API_KEY=""
CRUSOE_BASE_URL="https://api.crusoe.ai/v1"
CRUSOE_MODEL="deepseek-ai/DeepSeek-R1-0528"

# Local Ollama 
LOCAL_BASE_URL="http://localhost:11434/v1"
LOCAL_MODEL="mistral"

# Google HAI-DEF (Healthcare Data Engine API)
VITE_GOOGLE_CLOUD_API_KEY=""

# Google Gemini (Clinical insights from transcripts)
VITE_GOOGLE_GEMINI_KEY=""

# ElevenLabs (Voice Scribe)
VITE_ELEVENLABS_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# 3. Financial & Settlement Systems
# ─────────────────────────────────────────────────────────────────────────────
# Stripe (Autonomous Checkout Sessions)
VITE_STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# Paid.ai (Outcome-based Billing)
VITE_PAID_AI_API_KEY="your_paid_ai_key"

# Solana (Micropayments)
# Used only if real network interactions are built; by default uses Devnet testing.
VITE_SOLANA_RPC_ENDPOINT="https://api.devnet.solana.com"

# ─────────────────────────────────────────────────────────────────────────────
# 4. Agent Tunables (Incident Commander / Anomaly Detection)
# ─────────────────────────────────────────────────────────────────────────────
ANOMALY_VELOCITY_THRESHOLD="1.5" # rad/s
ANOMALY_POSITION_THRESHOLD="0.05" # metres

TELEMETRY_INTERVAL_MS="200"
MAX_LATENCY_MS="200"
REASONING_TIMEOUT_S="30"
MAX_RESPONSE_TOKENS="2048"
